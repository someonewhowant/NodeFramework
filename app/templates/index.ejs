<%- include('partials/header') %>

<div class="content">
    <h1>Программы обучения</h1>
    <p>Курсы в течение года.</p>
    <p>Расписание действует на: <%= data %> <b>(дата подставляется шаблоном)</b></p>
    
    <form action="/" method="post">
        <fieldset>
            <legend>Зарегистрируйтесь</legend>
            <p><label>Ваше имя: <input type="text" name="name"></label></p>
            <p><label>Ваш email: <input type="text" name="email"></label></p>
            <input type="submit" value="Регистрация" />
        </fieldset>
    </form>
</div>

<%- include('partials/footer') %>
